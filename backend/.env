# Ollama Configuration
# OLLAMA_HOST: Host where Ollama is running (default: http://localhost:11434)
# OLLAMA_MODEL: Model to use for note generation (default: qwen2.5-coder:7b)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:1.5b

# Anthropic API key is no longer needed
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here